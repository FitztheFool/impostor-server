  "version": "1.0.0",
  "description": "Real-time game server for Impostor",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -w --preserveWatchOutput\" \"nodemon --watch dist dist/index.js\"",

    "start": "node dist/index.js"
  },
  "license": "ISC",
  "dependencies": {
    "@kwizar/shared": "^1.0.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "typescript": "^5.8.3"
  }
